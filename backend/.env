# ── Flask ────────────────────────────────────────────────────
SECRET_KEY=change-me-in-production
JWT_SECRET_KEY=change-this-jwt-secret

# ── Database ─────────────────────────────────────────────────
# Connect to the MySQL Docker container via localhost:3306
# Format: mysql+pymysql://<user>:<password>@<host>/<database>
DATABASE_URL=mysql+pymysql://agriuser:agripassword@localhost:3306/smartagri

# ── CORS ─────────────────────────────────────────────────────
# Allow requests from the Vite dev server (port 8080)
CORS_ORIGINS=http://localhost:8080

# ── MySQL Docker (used by docker-compose.yml) ─────────────────
MYSQL_ROOT_PASSWORD=rootpassword
MYSQL_DATABASE=smartagri
MYSQL_USER=agriuser
MYSQL_PASSWORD=agripassword
